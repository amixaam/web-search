{
  "name": "web-search",
  "version": "1.0.0",
  "type": "module",
  "keywords": ["pi-package"],
  "bin": {
    "web-search": "./index.js"
  },
  "pi": {
    "extensions": ["./src/web-search"],
    "skills": ["./SKILL.md"]
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome ci ."
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^29.0.2",
    "node-html-parser": "^7.1.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": { "optional": true },
    "typebox": { "optional": true }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  }
}